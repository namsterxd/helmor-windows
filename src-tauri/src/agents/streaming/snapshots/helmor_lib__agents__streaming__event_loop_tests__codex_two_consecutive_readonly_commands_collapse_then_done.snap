  emitted:
    - kind: StreamingPartial
      message:
        role: assistant
        part_types:
          - tool-call(Bash)
        streaming: true
  side_effects: []
- event_type: item/completed
  emitted:
    - kind: Update
      messages:
        - role: assistant
          part_types:
            - tool-call(Bash)
          streaming: ~
  side_effects: []
- event_type: item/started
  emitted:
    - kind: StreamingPartial
