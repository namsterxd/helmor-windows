{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Helmor",
	"version": "0.1.0",
	"identifier": "build.helmor.app",
	"build": {
		"beforeDevCommand": "pnpm exec vite",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "cd sidecar && bun install --frozen-lockfile && bun run build && cp dist/helmor-sidecar dist/helmor-sidecar-$(rustc -vV | grep host | cut -d' ' -f2) && cd .. && pnpm run build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "Helmor",
				"width": 1300,
				"height": 810,
				"titleBarStyle": "Overlay",
				"trafficLightPosition": {
					"x": 12,
					"y": 20
				},
				"hiddenTitle": true,
				"center": true
			}
		],
		"security": {
			"csp": null,
			"assetProtocol": {
				"enable": true,
				"scope": {
					"allow": ["**"]
				}
			}
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"externalBin": ["../sidecar/dist/helmor-sidecar"],
		"resources": {
			"../sidecar/dist/vendor/": "vendor"
		},
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
